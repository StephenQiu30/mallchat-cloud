<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.stephen.cloud.user.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.stephen.cloud.user.model.entity.User">
