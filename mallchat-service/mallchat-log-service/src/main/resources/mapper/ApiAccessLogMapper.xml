<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.stephen.cloud.log.mapper.ApiAccessLogMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.stephen.cloud.log.model.entity.ApiAccessLog">
        <id column="id" property="id"/>
        <result column="trace_id" property="traceId"/>
        <result column="user_id" property="userId"/>
        <result column="method" property="method"/>
        <result column="path" property="path"/>
        <result column="query" property="query"/>
        <result column="status" property="status"/>
        <result column="latency_ms" property="latencyMs"/>
        <result column="client_ip" property="clientIp"/>
        <result column="user_agent" property="userAgent"/>
        <result column="referer" property="referer"/>
        <result column="request_size" property="requestSize"/>
        <result column="response_size" property="responseSize"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

</mapper>
